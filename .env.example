# Environment Variables
# Copy this file to .env and fill in your values. NEVER commit .env to source control.

# Linear
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxx
LINEAR_TEAM_ID=

# Slack
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Application
PORT=3000
NODE_ENV=development
APP_API_KEY=change-me-to-a-random-secret
APP_ADMIN_KEY=change-me-to-a-different-secret

# Database
DB_PATH=./data/bot.db

# Scheduler (Asia/Kolkata = IST)
SCHEDULE_1=0 13 * * *
SCHEDULE_2=0 16 * * *
SCHEDULE_3=0 18 * * *
SCHEDULE_TIMEZONE=Asia/Kolkata

# Rate Limiting
API_RATE_DELAY_MS=300